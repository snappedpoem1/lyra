# Lyra Oracle environment template
# Fill in the keys you use and adjust the paths for your machine.

# Genius API
GENIUS_TOKEN=

# Last.fm API
LASTFM_API_KEY=
LASTFM_API_SECRET=

# TheAudioDB
THEAUDIODB_API_KEY=1

# Polite API identification
LYRA_USER_AGENT=LyraOracle/1.0

# Spotify API
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# MusicBrainz
MB_APP_NAME=LyraOracle
MB_APP_VERSION=1.0
MB_CONTACT=you@example.com

# AcoustID
ACOUSTID_API_KEY=

# Discogs
DISCOGS_API_TOKEN=

# Qobuz
QOBUZ_USERNAME=
QOBUZ_PASSWORD=
QOBUZ_QUALITY=7
QOBUZ_SERVICE_URL=http://localhost:7700

# Lidarr / Prowlarr / Real-Debrid
LIDARR_URL=http://localhost:8686
PROWLARR_URL=http://localhost:9696
PROWLARR_API_KEY=
REAL_DEBRID_KEY=

# Optional rclone mount
RCLONE_REMOTE_NAME=
RCLONE_MOUNT_DRIVE=

# Core paths
LYRA_BASE_PATH=.
LYRA_DB_PATH=./lyra_registry.db
LIBRARY_BASE=
DOWNLOADS_FOLDER=./downloads
STAGING_FOLDER=./staging
REPORTS_FOLDER=./Reports
PLAYLISTS_FOLDER=./playlists
VIBES_FOLDER=./vibes
SPOTIFY_DATA_DIR=

# Chroma / model cache
CHROMA_PATH=./chroma_storage
CHROMA_COLLECTION=clap_embeddings
HF_HOME=./hf_cache
HUGGINGFACE_HUB_CACHE=./hf_cache/hub

# Download preferences
PREFERRED_CODEC=m4a
PREFERRED_QUALITY=256
SLEEP_MIN=5
SLEEP_MAX=15

# ---------------------------------------------------------------------------
# LLM configuration  — choose ONE profile by uncommenting it:
# ---------------------------------------------------------------------------
#
# PROFILE A: Local (LM Studio / Ollama) — default, zero cost but resource-heavy
#   Swap the model for any GGUF you have loaded.
LYRA_LLM_PROVIDER=lmstudio
LYRA_LLM_BASE_URL=http://127.0.0.1:1234/v1
LYRA_LLM_MODEL=qwen2.5-14b-instruct
LYRA_LLM_API_KEY=
LYRA_LLM_FALLBACK_MODEL=
LYRA_LLM_TIMEOUT_SECONDS=30
#
# PROFILE B: Groq (fastest cloud option, generous free tier)
#   Sign up at https://console.groq.com  then copy your API key.
#   Models: llama-3.3-70b-versatile | mixtral-8x7b-32768 | gemma2-9b-it
#LYRA_LLM_PROVIDER=openai_compatible
#LYRA_LLM_BASE_URL=https://api.groq.com/openai/v1
#LYRA_LLM_MODEL=llama-3.3-70b-versatile
#LYRA_LLM_API_KEY=gsk_YOUR_GROQ_KEY_HERE
#LYRA_LLM_FALLBACK_MODEL=gemma2-9b-it
#LYRA_LLM_TIMEOUT_SECONDS=30
#
# PROFILE C: OpenRouter (pay-per-token, 100+ models including free ones)
#   Sign up at https://openrouter.ai  — free models available (google/gemma-3-27b-it:free etc.)
#   Set OPENROUTER_HTTP_REFERER to identify your app (optional).
#LYRA_LLM_PROVIDER=openai_compatible
#LYRA_LLM_BASE_URL=https://openrouter.ai/api/v1
#LYRA_LLM_MODEL=meta-llama/llama-3.3-70b-instruct
#LYRA_LLM_API_KEY=sk-or-YOUR_OPENROUTER_KEY_HERE
#LYRA_LLM_FALLBACK_MODEL=google/gemma-3-27b-it:free
#LYRA_LLM_TIMEOUT_SECONDS=30
#
# PROFILE D: Anthropic (best reasoning quality, pay-per-token)
#   Sign up at https://console.anthropic.com
#   Models: claude-haiku-3-5 (cheapest/fastest) | claude-sonnet-4-5
#LYRA_LLM_PROVIDER=anthropic
#LYRA_LLM_BASE_URL=
#LYRA_LLM_MODEL=claude-haiku-3-5
#LYRA_LLM_API_KEY=sk-ant-YOUR_ANTHROPIC_KEY_HERE
#LYRA_LLM_FALLBACK_MODEL=
#LYRA_LLM_TIMEOUT_SECONDS=30
#
# PROFILE E: Disabled (all LLM features fall back to keyword/heuristic mode)
#LYRA_LLM_PROVIDER=disabled
# ---------------------------------------------------------------------------

LYRA_API_TOKEN=
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,null
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=
OPENAI_API_KEY=

# Bootstrap
LYRA_LM_AUTOLOAD=1
LYRA_BOOTSTRAP_QOBUZ=0

# Lyra Protocol
LYRA_PROTOCOL_INDEXER_URL=http://localhost:9696
LYRA_PROTOCOL_INDEXER_KEY=
LYRA_PROTOCOL_NODE_URL=http://localhost:5030
LYRA_PROTOCOL_NODE_API_BASE=/api/v0
LYRA_PROTOCOL_NODE_KEY=
LYRA_PROTOCOL_NODE_USER=
LYRA_PROTOCOL_NODE_PASS=
LYRA_PROTOCOL_CACHE_URL=https://api.real-debrid.com/rest/1.0
LYRA_PROTOCOL_CACHE_TOKEN=
LYRA_PROTOCOL_TRANSPORT_HOST=localhost
LYRA_PROTOCOL_TRANSPORT_PORT=6500
LYRA_PROTOCOL_TRANSPORT_USER=
LYRA_PROTOCOL_TRANSPORT_PASS=
LYRA_PROTOCOL_MB_APP=LyraSystem
LYRA_PROTOCOL_MB_VERSION=1.0
LYRA_PROTOCOL_MB_CONTACT=you@example.com

# PlayFaux / BeefWeb
BEEFWEB_HOST=localhost
BEEFWEB_PORT=8880
BEEFWEB_POLL_INTERVAL=0.5
BEEFWEB_SKIP_THRESHOLD=0.5
TASTE_WEIGHT_COMPLETED=1.0
TASTE_WEIGHT_SKIPPED=0.5
