# ╔══════════════════════════════════════════════════════════════╗
# ║           MUSIC ORACLE — LIVE CONFIGURATION                 ║
# ║  Keys injected from Lyra installer. Ready to run.           ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Genius API (lyrics + song metadata) ──────────────────────
GENIUS_TOKEN=

# ── Last.fm API (artist bios, tags, similar artists) ─────────
LASTFM_API_KEY=
LASTFM_API_SECRET=

# ── Spotify API (live playlist sync + search) ────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── MusicBrainz ──────────────────────────────────────────────
MB_APP_NAME=LyraOracle
MB_APP_VERSION=9.0
MB_CONTACT=you@example.com

# ── AcoustID ────────────────────────────────────────────────
ACOUSTID_API_KEY=

# ── Discogs ─────────────────────────────────────────────────
DISCOGS_API_TOKEN=

# ── Qobuz (hi-fi streaming/download) ───────────────────────────
# app_id and app_secret are auto-extracted by qobuz-dl — only user creds needed
QOBUZ_USERNAME=
QOBUZ_PASSWORD=
QOBUZ_QUALITY=7
QOBUZ_SERVICE_URL=http://localhost:7700

# ── Lidarr (artist monitoring + release discovery) ──────────
# Paste your Lidarr API key after first launch (Settings > General)
LIDARR_URL=http://localhost:8686


# ── Prowlarr Indexer ─────────────────────────────────────────
# Paste your Prowlarr API key after first launch
PROWLARR_URL=http://localhost:9696
PROWLARR_API_KEY=

# ── Real-Debrid (premium link resolver) ──────────────────────
REAL_DEBRID_KEY=

# ── Rclone Cloud Mount ───────────────────────────────────────
RCLONE_REMOTE_NAME=lyra_remote
RCLONE_MOUNT_DRIVE=L:

# ── Paths ────────────────────────────────────────────────────
LYRA_BASE_PATH=C:\MusicOracle
LYRA_DB_PATH=C:\MusicOracle\lyra_registry.db
LIBRARY_BASE=A:\music\Active Music
DOWNLOADS_FOLDER=C:\MusicOracle\downloads
STAGING_FOLDER=C:\MusicOracle\staging
REPORTS_FOLDER=C:\MusicOracle\Reports
PLAYLISTS_FOLDER=C:\MusicOracle\Playlists
VIBES_FOLDER=A:\music\Vibes
SPOTIFY_DATA_DIR=

# ── ChromaDB (sonic DNA embeddings) ──────────────────────────
CHROMA_PATH=C:\MusicOracle\chroma_storage
CHROMA_COLLECTION=clap_embeddings

# ── Model Cache ─────────────────────────────────────────────
HF_HOME=C:\MusicOracle\hf_cache
HUGGINGFACE_HUB_CACHE=C:\MusicOracle\hf_cache\hub

# ── Download Preferences ─────────────────────────────────────
PREFERRED_CODEC=m4a
PREFERRED_QUALITY=256
SLEEP_MIN=5
SLEEP_MAX=15

# ── LLM (Agent) ──────────────────────────────────────────────
LYRA_LLM_PROVIDER=local
LYRA_LLM_BASE_URL=http://localhost:1234/v1
LYRA_LLM_MODEL=qwen2.5-14b-instruct
LYRA_LLM_API_KEY=
LYRA_LLM_FALLBACK_MODEL=
LYRA_LLM_TIMEOUT_SECONDS=30
LYRA_API_TOKEN=
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,null
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OPENAI_API_KEY=

# ── Bootstrap ──────────────────────────────────────────────
# Set to 1 to auto-load the LLM model on startup
LYRA_LM_AUTOLOAD=1
# Set to 1 to include Qobuz Docker service in bootstrap
LYRA_BOOTSTRAP_QOBUZ=0

# Lyra Protocol (Unified Asset Ingestion & Archival System)
LYRA_PROTOCOL_INDEXER_URL=http://localhost:9696
LYRA_PROTOCOL_INDEXER_KEY=
LYRA_PROTOCOL_NODE_URL=http://localhost:5030
LYRA_PROTOCOL_NODE_API_BASE=/api/v0
LYRA_PROTOCOL_NODE_KEY=
LYRA_PROTOCOL_NODE_USER=slskd
LYRA_PROTOCOL_NODE_PASS=slskd
LYRA_PROTOCOL_CACHE_URL=https://api.real-debrid.com/rest/1.0
LYRA_PROTOCOL_CACHE_TOKEN=
LYRA_PROTOCOL_TRANSPORT_HOST=localhost
LYRA_PROTOCOL_TRANSPORT_PORT=6500
LYRA_PROTOCOL_TRANSPORT_USER=admin
LYRA_PROTOCOL_TRANSPORT_PASS=admin
LYRA_PROTOCOL_MB_APP=LyraSystem
LYRA_PROTOCOL_MB_VERSION=2.0
LYRA_PROTOCOL_MB_CONTACT=admin@localhost
