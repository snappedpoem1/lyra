{
  "$schema": "https://schema.tauri.app/config/2",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../build"
  },
  "productName": "Cassette",
  "version": "0.1.0",
  "identifier": "com.lyra.player",
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cassette",
        "width": 1680,
        "height": 1020,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false,
        "useHttpsScheme": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "Cassette is a local-first music intelligence workspace powered by Lyra.",
    "longDescription": "Cassette is the desktop shell for Lyra, a local-first music intelligence companion for discovery, bridge finding, playlist authorship, and explainable guided listening.",
    "copyright": "Cassette / Lyra Oracle contributors",
    "resources": [
      "bin"
    ],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false
      },
      "wix": {
        "language": "en-US"
      }
    }
  }
}
