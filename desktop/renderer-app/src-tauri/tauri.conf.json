{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Lyra Oracle",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "identifier": "com.lyra.oracle",
      "targets": "all",
      "shortDescription": "Local-first music intelligence system",
      "longDescription": "Lyra Oracle is a local-first music intelligence system for personally owned libraries. Discover, score, and acquire music through a unified desktop interface backed by a bundled Python engine.",
      "copyright": "Lyra Oracle contributors",
      "resources": [
        "../../../.lyra-build/bin"
      ],
      "icon": [
        "icons/icon.ico",
        "icons/icon.png"
      ],
      "windows": {
        "nsis": {
          "installMode": "currentUser",
          "languages": ["English"],
          "displayLanguageSelector": false
        },
        "wix": {
          "language": "en-US"
        }
      }
    },
    "systemTray": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": false
    },
    "windows": [
      {
        "title": "Lyra Oracle",
        "width": 1680,
        "height": 1020,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ]
  }
}
