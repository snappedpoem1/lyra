{
  "$schema": "https://schema.tauri.app/config/2",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../scripts/run_tauri_before_build.ps1",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "productName": "Lyra Oracle",
  "version": "0.1.0",
  "identifier": "com.lyra.oracle",
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lyra Oracle",
        "width": 1680,
        "height": 1020,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false,
        "useHttpsScheme": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "Local-first media library and player",
    "longDescription": "Lyra is a local-first media library and player for personally owned libraries, powered by Lyra Core. Discover, score, and acquire music through a unified desktop interface backed by a bundled Python engine.",
    "copyright": "Lyra Oracle contributors",
    "resources": [
      "bin"
    ],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false
      },
      "wix": {
        "language": "en-US"
      }
    }
  }
}
