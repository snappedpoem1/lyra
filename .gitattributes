# Normalize text files
* text=auto

# Keep shell scripts LF
*.sh text eol=lf
*.bash text eol=lf

# Keep PowerShell scripts CRLF (Windows-friendly)
*.ps1 text eol=crlf
*.psm1 text eol=crlf

# Keep batch files CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Keep markdown/configs LF
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.xml text eol=lf
